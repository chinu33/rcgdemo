# ============================================================
# RCG Multi-Agent Command Center — Environment Configuration
# Copy this file to `.env` and fill in your values.
# ============================================================

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-3-pro

# Pricing per 1M tokens (USD). Adjust to match current Gemini 3 pricing.
GEMINI_INPUT_COST_PER_1M=1.25
GEMINI_OUTPUT_COST_PER_1M=10.00

# --- LangSmith Observability (optional but recommended) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=rcg-command-center
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Server ---
APP_HOST=127.0.0.1
APP_PORT=8000

# --- Demo Mode ---
# When true, falls back to scripted agent responses if no GOOGLE_API_KEY is set.
# Useful for offline demos.
DEMO_MODE_FALLBACK=true
